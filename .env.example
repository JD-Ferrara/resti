# This file is for local development reference only.
# In production (Vercel), set all variables in the Vercel dashboard.
# See README for instructions.

# ── App (Vercel serverless + Vite frontend) ───────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
VITE_SUPABASE_URL=your_supabase_project_url_here
VITE_SUPABASE_ANON_KEY=your_supabase_publishable_key_here

# ── Pipeline scripts (server-side only, never exposed to browser) ─
# Google Places API (New) — enable "Places API (New)" in Google Cloud Console
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Supabase service role key — for write access from pipeline scripts
# Find in: Supabase Dashboard → Project Settings → API → service_role (secret)
# NEVER commit this value or expose it to the browser
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here
